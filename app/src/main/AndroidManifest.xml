<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="com.miui.home.permission.ADD_WIDGET_TO_HOME_SCREEN" />
    <uses-permission android:name="com.oppo.launcher.permission.READ_SETTINGS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".UfiToolsApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UFITOOLSWidget"
        android:usesCleartextTraffic="true"
        android:enableOnBackInvokedCallback="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.UFITOOLSWidget">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <activity
            android:name=".SetupActivity"
            android:label="初次配置"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".SettingsActivity"
            android:label="设置"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".AppSettingsActivity"
            android:label="软件设置"
            android:parentActivityName=".SettingsActivity"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".NotificationSettingsActivity"
            android:label="通知管理"
            android:parentActivityName=".SettingsActivity"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".AlertHistoryActivity"
            android:label="警报历史"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".BackgroundKeepAliveActivity"
            android:label="后台保活配置"
            android:parentActivityName=".NotificationSettingsActivity"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".ConfigModifyActivity"
            android:label="配置修改"
            android:parentActivityName=".SettingsActivity"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".WidgetSettingsActivity"
            android:label="小组件设置"
            android:parentActivityName=".SettingsActivity"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".WidgetDynamicColorActivity"
            android:label="动态配色"
            android:parentActivityName=".ExperimentalFeaturesActivity"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".AboutActivity"
            android:label="关于"
            android:parentActivityName=".SettingsActivity"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".ExperimentalFeaturesActivity"
            android:label="实验功能"
            android:parentActivityName=".SettingsActivity"
            android:theme="@style/Theme.UFITOOLSWidget" />


        <activity
            android:name=".DebugLogActivity"
            android:label="调试日志"
            android:parentActivityName=".AboutActivity"
            android:process=":crash_handler"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <activity
            android:name=".AddWidgetActivity"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.UFITOOLSWidget.Transparent" />

        <activity
            android:name=".ImageCropActivity"
            android:label="调整背景图片"
            android:theme="@style/Theme.UFITOOLSWidget" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".WidgetAddedReceiver"
            android:exported="true" />

        <receiver
            android:name=".widget.WifiWidget4x2"
            android:exported="true"
            android:enabled="true"
            android:label="UFI 状态 (4x2)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="com.ufi_toolswidget.ACTION_WIDGET_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_4x2_info" />
        </receiver>

        <!-- 2×1 迷你版暂时禁用 -->
        <receiver
            android:name=".widget.WifiWidget2x1"
            android:exported="true"
            android:enabled="false"
            android:label="UFI 迷你 (2×1)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="com.ufi_toolswidget.ACTION_WIDGET_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_2x1_info" />
        </receiver>

        <!-- 4×1 条形版暂时禁用 -->
        <receiver
            android:name=".widget.WifiWidget4x1"
            android:exported="true"
            android:enabled="false"
            android:label="UFI 条形 (4×1)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="com.ufi_toolswidget.ACTION_WIDGET_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_4x1_info" />
        </receiver>

        <!-- 4×4 详情版暂时禁用 -->
        <receiver
            android:name=".widget.WifiWidget4x4"
            android:exported="true"
            android:enabled="false"
            android:label="UFI 详情 (4×4)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="com.ufi_toolswidget.ACTION_WIDGET_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_4x4_info" />
        </receiver>
        <!-- 后台保活前台服务 -->
        <service
            android:name=".service.BackgroundMonitorService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- 开机自动恢复保活服务 -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- 无障碍保活服务（提高进程优先级） -->
        <service
            android:name=".service.KeepAliveAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>

</manifest>
