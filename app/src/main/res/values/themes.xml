<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.UFITOOLSWidget" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/sakura_pink</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/sakura_pink_light</item>
        <item name="colorOnPrimaryContainer">@color/sakura_pink_dark</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/sakura_pink_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.UFITOOLSWidget.Transparent" parent="Theme.UFITOOLSWidget">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- 弹窗动画：弹性进入 + 收缩退出 -->
    <style name="DialogAnimationTheme">
        <item name="android:windowEnterAnimation">@anim/dialog_enter_spring</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit_shrink</item>
    </style>

    <!-- 自定义输入框样式：圆角填充式，与卡片风格统一 -->
    <style name="AppTextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="hintTextAppearance">@style/AppTextInputHint</item>
    </style>

    <style name="AppTextInputHint" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">13sp</item>
    </style>
</resources>
