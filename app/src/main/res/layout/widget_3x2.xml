<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_shape">

    <!-- 第一行：型号 + 版本 | 电量 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_model"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#74B9FF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="--" />

        <TextView
            android:id="@+id/tv_app_ver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="#636E72"
            android:textSize="12sp"
            android:maxLines="1"
            android:text="" />

        <TextView
            android:id="@+id/tv_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#00B894"
            android:textStyle="bold"
            android:textSize="14sp"
            android:maxLines="1"
            android:text="--%" />
    </LinearLayout>

    <!-- 第二行：今日流量 / 本月流量 大数字 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp">

        <!-- 左：今日流量 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今日流量"
                android:textColor="#0984E3"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginTop="2dp">
                <TextView
                    android:id="@+id/tv_daily"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#DFE6E9"
                    android:textStyle="bold"
                    android:textSize="32sp"
                    android:maxLines="1"
                    android:text="--" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GB"
                    android:textColor="#636E72"
                    android:textSize="14sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#44FFFFFF" />

        <!-- 右：本月流量 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="本月流量"
                android:textColor="#0984E3"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginTop="2dp">
                <TextView
                    android:id="@+id/tv_flow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#DFE6E9"
                    android:textStyle="bold"
                    android:textSize="32sp"
                    android:maxLines="1"
                    android:text="--" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GB"
                    android:textColor="#636E72"
                    android:textSize="14sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 第三行：温度 CPU 运营商 信号 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_temp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FFEAA7"
            android:textSize="12sp"
            android:maxLines="1"
            android:gravity="center"
            android:text="--" />

        <TextView
            android:id="@+id/tv_cpu_mem"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#B2BEC3"
            android:textSize="12sp"
            android:maxLines="1"
            android:gravity="center"
            android:text="--" />

        <TextView
            android:id="@+id/tv_net_type"
            android:layout_width="0dp"
            android:layout_weight="1.2"
            android:layout_height="wrap_content"
            android:textColor="#0984E3"
            android:textSize="12sp"
            android:maxLines="1"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/tv_signal"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:gravity="center"
            android:text="--" />
    </LinearLayout>
</LinearLayout>
