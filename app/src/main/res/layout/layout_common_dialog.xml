<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/common_dialog_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="22dp"
    android:background="@drawable/bg_widget_card">

    <!-- 标题栏：图标 + 标题文本 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/common_dialog_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_router" />
        <TextView
            android:id="@+id/common_dialog_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="标题"
            android:textColor="@color/text_main"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/common_dialog_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="vertical"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
        android:scrollbarSize="10dp"
        android:scrollbarStyle="outsideOverlay"
        android:fadeScrollbars="true"
        android:scrollbarDefaultDelayBeforeFade="2000"
        android:scrollbarFadeDuration="500"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/common_dialog_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="4dp" />
    </ScrollView>

    <!-- 按钮区域：作为固定页脚 -->
    <LinearLayout
        android:id="@+id/common_dialog_button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <View
            android:id="@+id/common_dialog_button_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_sub"
            android:alpha="0.08"
            android:layout_marginBottom="16dp" />

        <!-- 取消/确认 左右排列 -->
        <LinearLayout
            android:id="@+id/common_dialog_button_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/common_dialog_btn_secondary"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="取消"
                android:textSize="14sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone"
                app:cornerRadius="12dp"
                app:strokeColor="@color/text_sub" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/common_dialog_btn_primary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="确定"
                android:textSize="14sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"
                app:strokeWidth="0dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
