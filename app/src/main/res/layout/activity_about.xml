<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="关于"
                    android:textColor="@color/text_main"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="start|top"
                android:layout_marginTop="6dp"
                app:icon="@drawable/ic_arrow_back"
                app:iconTint="@color/text_main" />
        </FrameLayout>

        <!-- ==================== App 信息区域（无卡片容器） ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="22dp"
            android:paddingHorizontal="28dp"
            android:descendantFocusability="blocksDescendants">

            <ImageView
                android:id="@+id/iv_app_icon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="UFI-TOOLS Widget"
                android:src="@mipmap/ic_launcher"
                android:clickable="false"
                android:focusable="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="UFI-TOOLS Widget"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold"
                android:clickable="false"
                android:focusable="false" />

            <TextView
                android:id="@+id/tv_app_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Version 1.0.0"
                android:textColor="@color/text_main"
                android:alpha="0.45"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />

            <!-- 赞赏按钮 -->
            <LinearLayout
                android:id="@+id/btn_donate"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:id="@+id/iv_donate_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="5dp"
                    android:contentDescription="赞赏原版项目作者"
                    android:src="@drawable/ic_heart" />

                <TextView
                    android:id="@+id/tv_donate_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="赞赏原版项目作者"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:alpha="0.06"
                android:background="@color/text_sub" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:text="UFI-TOOLS Widget 是一款开源的随身 WiFi 桌面监控工具。支持实时查看 4G/5G 信号（含 RSRP/SINR 等）、流量统计、硬件温度、电池状态及存储空间。"
                android:textColor="@color/text_main"
                android:alpha="0.6"
                android:textSize="13sp"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <!-- ==================== 更新设置卡片 ==================== -->
        <LinearLayout
            style="@style/AppCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.5"
                    android:contentDescription="更新"
                    android:src="@drawable/ic_rocket" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="更新设置"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_update_settings"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:alpha="0.45"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="更多更新设置"
                    android:src="@drawable/ic_settings" />
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="4dp"
                android:alpha="0.06"
                android:background="@color/text_sub" />

            <!-- 检查更新区域（垂直堆叠：文字 + 全宽按钮） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="版本更新"
                    android:textColor="@color/text_main"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="10dp"
                    android:text="检查并下载最新版本"
                    android:textColor="@color/text_main"
                    android:alpha="0.4"
                    android:textSize="12sp" />

                <include
                    layout="@layout/layout_common_action_button"
                    android:id="@+id/btn_check_update"
                    android:layout_width="match_parent"
                    android:layout_height="44dp" />
            </LinearLayout>

            <!-- 更新状态区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="vertical">

                <ProgressBar
                    android:id="@+id/progress_update"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_update_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/text_main"
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== 开源地址 ==================== -->
        <include
            layout="@layout/layout_common_setting_item"
            android:id="@+id/card_github"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp" />

        <!-- ==================== 致谢 ==================== -->
        <include
            layout="@layout/layout_common_setting_item"
            android:id="@+id/card_thanks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp" />

        <!-- ==================== Footer ==================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Made with ❤ for UFI devices"
            android:textColor="@color/text_main"
            android:alpha="0.3"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
