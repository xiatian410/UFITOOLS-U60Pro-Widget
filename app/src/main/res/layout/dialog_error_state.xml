<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_widget_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/dialog_error_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_router_off" />
        <TextView
            android:id="@+id/dialog_error_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="连接异常"
            android:textColor="@color/text_main"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:maxHeight="300dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dialog_error_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.3"
                android:text="无法连接到设备，后台刷新已自动暂停以节省电量。"
                android:textColor="@color/text_sub"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:alpha="0.7">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_antenna"
                    android:layout_marginEnd="6dp"
                    app:tint="@color/text_main" />
                <TextView
                    android:id="@+id/dialog_error_target"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="192.168.0.1:80"
                    android:textColor="@color/text_main"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/dialog_error_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="设备恢复上线后将自动恢复刷新"
                android:textColor="@color/text_sub"
                android:textSize="12sp"
                android:alpha="0.6" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dialog_error_btn_retry"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:text="重新连接"
        android:textSize="14sp"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_signal_3"
        app:iconGravity="textStart"
        app:iconPadding="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dialog_error_btn_config"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:text="修改连接配置"
        android:textSize="14sp"
        app:cornerRadius="12dp"
        app:strokeColor="@color/text_sub" />

</LinearLayout>
