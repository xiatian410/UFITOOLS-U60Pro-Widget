<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg_shape">

    <!-- 顶部：型号 + 版本 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/tv_model"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#74B9FF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="--" />
        <TextView
            android:id="@+id/tv_app_ver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#636E72"
            android:textSize="10sp"
            android:maxLines="1"
            android:text="" />
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="8dp" />

    <!-- 中间区域：左右两列 + 电量区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- 左列：流量 + 信号 + 网络类型 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_flow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#DFE6E9"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="--" />

            <TextView
                android:id="@+id/tv_daily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#B2BEC3"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="--" />

            <TextView
                android:id="@+id/tv_signal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="--" />

            <TextView
                android:id="@+id/tv_net_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#0984E3"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />
        </LinearLayout>

        <!-- 右列：温度 + CPU/内存 + 存储 + IP -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFEAA7"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="--" />

            <TextView
                android:id="@+id/tv_cpu_mem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#B2BEC3"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/tv_storage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#B2BEC3"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/tv_client_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#636E72"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />
        </LinearLayout>

        <!-- 电量区 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#00B894"
                android:textStyle="bold"
                android:textSize="22sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="--%" />

            <TextView
                android:id="@+id/tv_voltage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#B2BEC3"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/tv_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#B2BEC3"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
