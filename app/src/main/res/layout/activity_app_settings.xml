<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="48dp">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="50dp"
                android:paddingBottom="50dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="软件设置"
                    android:textColor="@color/text_main"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="调整应用与小组件的显示风格"
                    android:textColor="@color/text_main"
                    android:alpha="0.6"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start|top"
                android:layout_marginTop="12dp"
                android:layout_marginStart="12dp"
                app:icon="@drawable/ic_arrow_back"
                app:iconTint="@color/text_main" />
        </FrameLayout>

        <!-- ========== 软件主题 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_eye"
                    app:tint="@color/sakura_dark" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="软件主题"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="34dp"
                android:layout_marginTop="4dp"
                android:text="设置应用与小组件的显示样式"
                android:textColor="@color/text_main"
                android:alpha="0.5"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_app_theme"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="14dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_app_theme_system"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="跟随系统"
                    android:textSize="13sp"
                    android:textColor="@color/text_main"
                    app:strokeColor="@color/sakura_primary"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_app_theme_light"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="浅色"
                    android:textSize="13sp"
                    android:textColor="@color/text_main"
                    app:strokeColor="@color/sakura_primary"
                    app:cornerRadius="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_app_theme_dark"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="深色"
                    android:textSize="13sp"
                    android:textColor="@color/text_main"
                    app:strokeColor="@color/sakura_primary"
                    app:cornerRadius="8dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <!-- ========== 颜色主题 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_eye"
                    app:tint="@color/sakura_dark" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="颜色主题"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="34dp"
                android:layout_marginTop="4dp"
                android:text="选择应用的颜色方案"
                android:textColor="@color/text_main"
                android:alpha="0.5"
                android:textSize="12sp" />

            <!-- 双栏主题卡片 -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:columnCount="2"
                android:rowCount="3">

                <!-- 默认 -->
                <LinearLayout
                    android:id="@+id/card_theme_default"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@drawable/bg_widget_card">

                    <View
                        android:id="@+id/preview_default"
                        android:layout_width="56dp"
                        android:layout_height="56dp" />

                    <TextView
                        android:id="@+id/label_default"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="默认"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/check_default"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="6dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 科技蓝 -->
                <LinearLayout
                    android:id="@+id/card_theme_blue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@drawable/bg_widget_card">

                    <View
                        android:id="@+id/preview_blue"
                        android:layout_width="56dp"
                        android:layout_height="56dp" />

                    <TextView
                        android:id="@+id/label_blue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="科技蓝"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/check_blue"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="6dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 薄荷绿 -->
                <LinearLayout
                    android:id="@+id/card_theme_mint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@drawable/bg_widget_card">

                    <View
                        android:id="@+id/preview_mint"
                        android:layout_width="56dp"
                        android:layout_height="56dp" />

                    <TextView
                        android:id="@+id/label_mint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="薄荷绿"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/check_mint"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="6dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 梦幻紫 -->
                <LinearLayout
                    android:id="@+id/card_theme_purple"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@drawable/bg_widget_card">

                    <View
                        android:id="@+id/preview_purple"
                        android:layout_width="56dp"
                        android:layout_height="56dp" />

                    <TextView
                        android:id="@+id/label_purple"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="梦幻紫"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/check_purple"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="6dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 活力暖橙 -->
                <LinearLayout
                    android:id="@+id/card_theme_orange"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@drawable/bg_widget_card">

                    <View
                        android:id="@+id/preview_orange"
                        android:layout_width="56dp"
                        android:layout_height="56dp" />

                    <TextView
                        android:id="@+id/label_orange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="活力暖橙"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/check_orange"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="6dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 自定义颜色入口 -->
                <LinearLayout
                    android:id="@+id/card_theme_custom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@drawable/bg_widget_card">

                    <View
                        android:id="@+id/preview_custom"
                        android:layout_width="56dp"
                        android:layout_height="56dp" />

                    <TextView
                        android:id="@+id/label_custom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="自定义"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/check_custom"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="6dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />
                </LinearLayout>
            </GridLayout>

            <!-- 自定义颜色编辑区（默认隐藏） -->
            <LinearLayout
                android:id="@+id/custom_color_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_widget_card"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自定义强调色"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/custom_color_swatch"
                        android:layout_width="40dp"
                        android:layout_height="40dp" />

                    <EditText
                        android:id="@+id/et_custom_color"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_widget_card"
                        android:gravity="center"
                        android:hint="输入颜色值，如 #FF5722"
                        android:inputType="text"
                        android:maxLength="9"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/text_main"
                        android:textColorHint="@color/text_sub"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_apply_custom_color"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="10dp"
                        android:text="应用"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="16dp"
                        app:cornerRadius="24dp"
                        app:backgroundTint="@color/sakura_dark" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_custom_color_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="支持 #RRGGBB 或 #AARRGGBB 格式"
                    android:textColor="@color/text_sub"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
