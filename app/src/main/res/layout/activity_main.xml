<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ==================== 加载状态 ==================== -->
    <ScrollView
        android:id="@+id/loading_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
        android:scrollbarSize="4dp"
        android:scrollbarStyle="outsideOverlay"
        android:fadeScrollbars="true"
        android:clipToPadding="false"
        android:fitsSystemWindows="true"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- 加载页品牌 Header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="44dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:id="@+id/loading_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UFITOOLS-Widget"
                        android:textColor="@color/text_sub"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:id="@+id/loading_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="正在连接设备..."
                        android:textColor="@color/text_sub"
                        android:textSize="13sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- 加载指示器区域 -->
            <LinearLayout
                android:id="@+id/loading_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="48dp">

                <com.ufi_toolswidget.view.LoadingAnimationView
                    android:id="@+id/loading_progress"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center" />

                <TextView
                    android:id="@+id/loading_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="请稍候"
                    android:textColor="@color/text_sub"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ==================== 主内容区域（完全固定，无滑动） ==================== -->
    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:visibility="gone">

        <!-- Header -->
        <FrameLayout
            android:id="@+id/main_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="28dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/main_tv_model"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:layout_marginHorizontal="8dp"
                    android:textColor="@color/text_main"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:gravity="center"
                    android:maxLines="1"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="18sp"
                    app:autoSizeMaxTextSize="48sp"
                    app:autoSizeStepGranularity="2sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/main_tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_main"
                    android:alpha="0.45"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- 左上角：警报历史按钮 -->
            <LinearLayout
                android:id="@+id/btn_alert_history"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_gravity="start|top"
                android:layout_marginTop="12dp"
                android:layout_marginStart="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="8dp">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/btn_alert_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_notification"
                        android:duplicateParentState="true" />
                    <View
                        android:id="@+id/alert_unread_dot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="-2dp"
                        android:layout_marginEnd="-2dp"
                        android:visibility="gone" />
                </FrameLayout>
                <TextView
                    android:id="@+id/btn_alert_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="警报"
                    android:textSize="13sp"
                    android:textColor="@color/text_main"
                    android:duplicateParentState="true" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_settings"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="8dp">
                <ImageView
                    android:id="@+id/btn_settings_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_settings"
                    android:duplicateParentState="true" />
                <TextView
                    android:id="@+id/btn_settings_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="设置"
                    android:textSize="13sp"
                    android:textColor="@color/text_main"
                    android:duplicateParentState="true" />
            </LinearLayout>
        </FrameLayout>

        <!-- 数据展示区：通过 Weight 分配空间实现适配 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- 实时卡片 -->
            <LinearLayout
                android:id="@+id/card_network"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_widget_card"
                android:padding="16dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/tv_section_network"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="实时状态"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:id="@+id/main_item_network"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageView
                            android:id="@+id/main_iv_antenna"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_antenna" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical"
                            android:clipChildren="false"
                            android:clipToPadding="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="网络"
                                android:textColor="@color/text_sub"
                                android:textSize="10sp" />
                            <TextView
                                android:id="@+id/main_tv_net_signal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_main"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="16dp"
                                android:layout_marginStart="-16dp"
                                android:layout_marginEnd="-16dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/main_item_temp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageView
                            android:id="@+id/main_iv_temp"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_temp" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical"
                            android:clipChildren="false"
                            android:clipToPadding="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="温度"
                                android:textColor="@color/text_sub"
                                android:textSize="10sp" />
                            <TextView
                                android:id="@+id/main_tv_temp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_main"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="16dp"
                                android:layout_marginStart="-16dp"
                                android:layout_marginEnd="-16dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/main_item_cpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageView
                            android:id="@+id/main_iv_cpu"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_cpu" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical"
                            android:clipChildren="false"
                            android:clipToPadding="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CPU"
                                android:textColor="@color/text_sub"
                                android:textSize="10sp" />
                            <TextView
                                android:id="@+id/main_tv_cpu"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_main"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="16dp"
                                android:layout_marginStart="-16dp"
                                android:layout_marginEnd="-16dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/main_item_mem"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageView
                            android:id="@+id/main_iv_chip"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chip" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical"
                            android:clipChildren="false"
                            android:clipToPadding="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="内存"
                                android:textColor="@color/text_sub"
                                android:textSize="10sp" />
                            <TextView
                                android:id="@+id/main_tv_mem"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_main"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="16dp"
                                android:layout_marginStart="-16dp"
                                android:layout_marginEnd="-16dp" />
                        </LinearLayout>
                    </LinearLayout>
                </GridLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/text_sub"
                    android:alpha="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/main_tv_daily"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00GB"
                            android:textColor="@color/accent"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="今日已用"
                            android:textColor="@color/text_sub"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="6dp"
                        android:background="@color/text_sub"
                        android:alpha="0.1" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/main_tv_flow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00GB"
                            android:textColor="@color/accent"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="本月累计"
                            android:textColor="@color/text_sub"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 硬件卡片 -->
            <LinearLayout
                android:id="@+id/card_device"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_widget_card"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="10dp"
                    android:text="硬件参数"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2">

                    <LinearLayout
                        android:id="@+id/main_item_battery"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1.1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="电池"
                            android:textColor="@color/text_sub"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/main_tv_battery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_main"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/main_tv_battery_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_sub"
                            android:textSize="10sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/main_item_firmware"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="固件版本"
                            android:textColor="@color/text_sub"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/main_tv_firmware"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_main"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/main_tv_firmware_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_sub"
                            android:textSize="8sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/main_item_storage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1.1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="存储空间"
                            android:textColor="@color/text_sub"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/main_tv_storage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_main"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/main_item_ip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="网络地址"
                            android:textColor="@color/text_sub"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/main_tv_client_ip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_main"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </GridLayout>
            </LinearLayout>

            <!-- 检查更新按钮 -->
            <include
                layout="@layout/layout_common_action_button"
                android:id="@+id/btn_check_update"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp" />

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
