<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 顶部型号与电量 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/main_tv_model"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="设备：F50"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#1A1D1F" />
                <TextView
                    android:id="@+id/main_tv_battery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="电量：--"
                    android:textColor="#00B894"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 详细数据网格 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/main_tv_flow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="本月总流量：--"
                    android:textColor="#33383F"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/main_tv_daily"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="今日已消耗：--"
                    android:textColor="#33383F"
                    android:textSize="16sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#EDF0F2" />

                <TextView
                    android:id="@+id/main_tv_signal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="网络信号：--"
                    android:textColor="#33383F"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/main_tv_temp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="核心温度：--"
                    android:textColor="#33383F"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/main_tv_sys"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="CPU: -- | 内存: --"
                    android:textColor="#33383F"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/main_tv_current"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="电流：--"
                    android:textColor="#6C757D"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/main_tv_voltage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="电压：--"
                    android:textColor="#6C757D"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/main_tv_storage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="存储：--"
                    android:textColor="#6C757D"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/main_tv_client_ip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="IP：--"
                    android:textColor="#6C757D"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_refresh"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_gravity="end"
                    android:layout_height="wrap_content"
                    android:text="刷新数据"
                    android:textColor="#0066FF" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 认证配置 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="系统配置"
                    android:textColor="#1A1D1F"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_token"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@android:drawable/edit_text"
                    android:hint="UFI-TOOLS 口令"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:text="admin" />

                <CheckBox android:id="@+id/cb_show_flow" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="显示月流量" />
                <CheckBox android:id="@+id/cb_show_signal" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="显示网络强度" />
                <CheckBox android:id="@+id/cb_show_temp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="显示 CPU 温度" />

                <Button
                    android:id="@+id/btn_save_settings"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#0066FF"
                    android:text="保存配置并同步"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 日志 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="调试日志" android:textStyle="bold" />
                    <Button android:id="@+id/btn_copy_logs" style="?android:attr/borderlessButtonStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="复制" android:textColor="#0066FF" />
                </RelativeLayout>
                <TextView android:id="@+id/tv_debug_log" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#F8F9FA" android:padding="12dp" android:text="等待采集..." android:textSize="10sp" android:textIsSelectable="true" android:minLines="4" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
