<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_shape">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/tv_model"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#74B9FF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="--" />
        <TextView
            android:id="@+id/tv_net_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#0984E3"
            android:textSize="9sp"
            android:maxLines="1"
            android:text="" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"
        android:background="#44FFFFFF" />

    <TextView
        android:id="@+id/tv_flow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#DFE6E9"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="--" />

    <TextView
        android:id="@+id/tv_daily"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#B2BEC3"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="--" />

    <TextView
        android:id="@+id/tv_signal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="--" />

    <TextView
        android:id="@+id/tv_temp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#FFEAA7"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="--" />

    <!-- 用 Space 撑开剩余空间，电量在底部 -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end">

        <TextView
            android:id="@+id/tv_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#00B894"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="--%" />
    </LinearLayout>
</LinearLayout>
