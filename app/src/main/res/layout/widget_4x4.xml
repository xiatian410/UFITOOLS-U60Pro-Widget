<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:elevation="6dp"
    android:outlineProvider="background"
    android:background="@drawable/bg_widget_mask_transparent">

    <!-- 背景图层 -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/bg_widget_mask" />

    <!-- 描边层 -->
    <ImageView
        android:id="@+id/widget_bg_stroke"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/bg_widget_stroke" />

    <!-- 正常数据内容区 -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp">

        <!-- ========= Row 1: 路由器图标 + 设备型号 + 版本 + 应用版本 ========= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_router"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_router"
                android:scaleType="fitCenter"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tv_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..."
                android:textColor="#777777"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="..."
                android:textColor="#777777"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- 短信图标 + 未读数量（未读为 0 时隐藏） -->
            <ImageView
                android:id="@+id/iv_sms"
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_sms"
                android:contentDescription="@null"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_sms_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text=""
                android:textColor="#777777"
                android:textSize="12sp"
                android:maxLines="1"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ========= Row 2: 信号格数 + 网络类型 + 信号dBm + 电池图标 + 电量 + 充电 ========= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_signal_bars"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_signal_0"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/iv_network"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_network_5g"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_no_network"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="无网络"
                android:textColor="#777777"
                android:textSize="9sp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/iv_battery"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_battery_0"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="--"
                android:textColor="#777777"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_charging"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text=""
                android:textColor="#F59E0B"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ========= 水平分割线 ========= -->
        <FrameLayout
            android:id="@+id/divider_flow"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="#E5E5E5" />

        <!-- ========= Row 3: 今日流量 + 本月流量 (两列) ========= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 左列：今日流量 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_daily_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日流量"
                    android:textColor="#222222"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_daily"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#111111"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_daily_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:layout_marginStart="2dp"
                        android:text="GB"
                        android:textColor="#777777"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 右列：本月流量 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_flow_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本月流量"
                    android:textColor="#222222"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_flow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#111111"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_flow_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:layout_marginStart="2dp"
                        android:text="GB"
                        android:textColor="#777777"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ========= Row 4: 温度 + CPU + 内存 ========= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_temp"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_temp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/tv_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:text="--"
                    android:textColor="#777777"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_cpu"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_cpu"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/tv_cpu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:text="--"
                    android:textColor="#777777"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_chip"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_chip"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/tv_mem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:text="--"
                    android:textColor="#777777"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ========= Row 5: 天线图标 + 信号 dBm 详情 ========= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_antenna"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_antenna"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_signal_dbm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="--"
                android:textColor="#777777"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ========= Row 6: 更新时间 ========= -->
        <TextView
            android:id="@+id/tv_update_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="..."
            android:textColor="#777777"
            android:textSize="11sp" />

    </LinearLayout>
    <!-- end of widget_content -->

    <!-- ========= 错误覆盖层：全屏居中显示连接失败 ========= -->
    <LinearLayout
        android:id="@+id/widget_error_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:clickable="false">

        <ImageView
            android:id="@+id/widget_error_icon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_router_off"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/widget_error_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="设备连接失败"
            android:textColor="#777777"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_error_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="点击重试"
            android:textColor="#999999"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
