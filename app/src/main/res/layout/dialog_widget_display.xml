<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="8dp">

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cb_show_flow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="展示流量数据"
        app:buttonTint="@color/sakura_primary" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cb_show_temp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="展示硬件温度"
        app:buttonTint="@color/sakura_primary" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cb_show_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="展示设备名称"
        app:buttonTint="@color/sakura_primary" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cb_show_signal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="展示信号详情"
        app:buttonTint="@color/sakura_primary" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cb_show_battery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="展示电池状态"
        app:buttonTint="@color/sakura_primary" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cb_show_cpu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="展示CPU占用"
        app:buttonTint="@color/sakura_primary" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cb_show_mem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="展示内存占用"
        app:buttonTint="@color/sakura_primary" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cb_show_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="展示更新时间"
        app:buttonTint="@color/sakura_primary" />

</LinearLayout>
