<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="50dp"
                android:paddingBottom="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="小组件设置"
                    android:textColor="@color/text_main"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="自定义小组件显示内容与行为"
                    android:textColor="@color/text_main"
                    android:alpha="0.55"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start|top"
                android:layout_marginTop="12dp"
                android:layout_marginStart="12dp"
                app:icon="@drawable/ic_arrow_back"
                app:iconTint="@color/text_main" />
        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Widget Theme (提升到第一栏) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="小组件主题"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_widget_theme"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_widget_theme_follow"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="跟随应用"
                        android:textSize="12sp"
                        android:textColor="@color/text_main"
                        app:strokeColor="@color/sakura_primary"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_widget_theme_light"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="浅色"
                        android:textSize="13sp"
                        android:textColor="@color/text_main"
                        app:strokeColor="@color/sakura_primary"
                        app:cornerRadius="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_widget_theme_dark"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="深色"
                        android:textSize="13sp"
                        android:textColor="@color/text_main"
                        app:strokeColor="@color/sakura_primary"
                        app:cornerRadius="8dp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- Display Items (双栏 GridLayout) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="显示信息"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:columnCount="2">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_show_flow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="展示流量数据"
                        app:buttonTint="@color/sakura_primary" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_show_temp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="展示硬件温度"
                        app:buttonTint="@color/sakura_primary" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_show_model"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="展示设备名称"
                        app:buttonTint="@color/sakura_primary" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_show_signal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="展示信号详情"
                        app:buttonTint="@color/sakura_primary" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_show_battery"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="展示电池状态"
                        app:buttonTint="@color/sakura_primary" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_show_cpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="展示CPU占用"
                        app:buttonTint="@color/sakura_primary" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_show_mem"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="展示内存占用"
                        app:buttonTint="@color/sakura_primary" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_show_time"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="展示更新时间"
                        app:buttonTint="@color/sakura_primary" />
                </GridLayout>
            </LinearLayout>

            <!-- Refresh Interval -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="刷新频率"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_interval"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="自动刷新间隔"
                    app:boxStrokeColor="@color/sakura_primary"
                    app:hintTextColor="@color/sakura_dark">

                    <AutoCompleteTextView
                        android:id="@+id/sp_interval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textSize="14sp"
                        android:textColor="@color/text_main" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="28dp"
                android:text="保存配置"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="30dp"
                app:backgroundTint="@color/sakura_dark"
                android:elevation="6dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
