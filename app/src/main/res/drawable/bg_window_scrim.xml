<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 底层：白色→樱花粉渐变 -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#FFFFFF"
                android:centerColor="#FCE4EC"
                android:endColor="#F8BBD0"
                android:type="linear" />
        </shape>
    </item>
    <!-- 上层：极浅半透明白色遮罩，统一覆盖状态栏区域 -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="#26FFFFFF"
                android:endColor="#0DFFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
